# Railway PostgreSQL connection string. In Railway, add this as a service variable.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# Set to false only for a local Postgres instance without TLS.
PGSSL=true
# Long random string used to sign admin sessions. Required before public use.
AUTH_SECRET=replace-with-a-long-random-secret
